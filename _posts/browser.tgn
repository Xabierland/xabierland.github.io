lizable por el simple hecho de ser CLI tiene un puesto en mi corazon.","cspan":1,"rspan":1,"markup":[1,110]}],[{"value":"vimb","cspan":1,"rspan":1,"markup":[1,4]},{"value":"GPL","cspan":1,"rspan":1,"markup":[1,3]},{"value":"Excelente","cspan":1,"rspan":1,"markup":[1,9]},{"value":"¿Te gusta vim? Pues esto es lo mismo pero como navegador. Idea similar a Qutebrowser pero con interfaz mas minimalista,","cspan":1,"rspan":1,"markup":[1,119]}],[{"value":"Surf","cspan":1,"rspan":1,"markup":[1,4]},{"value":"MIT","cspan":1,"rspan":1,"markup":[1,3]},{"value":"Excelente","cspan":1,"rspan":1,"markup":[1,9]},{"value":"Junto con Lynx y vimb es el minimalismo y la configurabilidad al limite.","cspan":1,"rspan":1,"markup":[1,72]}],[{"value":"webbrowser.git","cspan":1,"rspan":1,"markup":[1,14]},{"value":"GPL","cspan":1,"rspan":1,"markup":[1,3]},{"value":"Excelente","cspan":1,"rspan":1,"markup":[1,9]},{"value":"Navegador web basico pero muy efectivo. Equilibrio entre privacidad, minimalismo y usabilidad.","cspan":1,"rspan":1,"markup":[1,94]}]]},"theme":null,"fixed_layout":false,"markup":{"instances":[{},{"style":{}},null]},"options":{}}